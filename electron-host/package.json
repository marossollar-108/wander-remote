{
  "name": "wander-remote-host",
  "version": "1.0.0",
  "description": "Wander Remote Host — remote desktop server",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "author": "Tulave kino",
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "com.wanderhub.remotehost",
    "productName": "Wander Remote Host",
    "mac": {
      "category": "public.app-category.utilities",
      "target": ["dmg"],
      "hardenedRuntime": false
    },
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    }
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "robotjs": "^0.7.0",
    "screenshot-desktop": "^1.15.3",
    "ws": "^8.20.0"
  }
}
